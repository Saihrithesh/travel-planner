{
  "info": {
    "name": "Travel Planner API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\",\n    \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Trips",
      "item": [
        {
          "name": "Get All Trips",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/trips",
              "host": ["{{baseUrl}}"],
              "path": ["trips"]
            }
          }
        },
        {
          "name": "Create Trip",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/trips",
              "host": ["{{baseUrl}}"],
              "path": ["trips"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Summer in Paris\",\n    \"startDate\": \"2024-06-01T00:00:00Z\",\n    \"endDate\": \"2024-06-10T00:00:00Z\",\n    \"budget\": 3000,\n    \"preferences\": [\"culture\", \"food\"],\n    \"destinations\": [\n        {\n            \"name\": \"Paris, France\",\n            \"location\": \"Eiffel Tower\"\n        }\n    ]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "External",
      "item": [
        {
          "name": "Get Weather",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/destinations/weather?lat=48.8566&lon=2.3522",
              "host": ["{{baseUrl}}"],
              "path": ["destinations", "weather"],
              "query": [
                { "key": "lat", "value": "48.8566" },
                { "key": "lon", "value": "2.3522" }
              ]
            }
          }
        },
        {
          "name": "AI Itinerary",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/destinations/ai-planner",
              "host": ["{{baseUrl}}"],
              "path": ["destinations", "ai-planner"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n    \"destination\": \"Paris\",\n    \"days\": 3,\n    \"preferences\": \"Culture, Museums, Food\"\n}"
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "token", "value": "YOUR_JWT_TOKEN_HERE" }
  ]
}
