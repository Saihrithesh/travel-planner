NODE_ENV=development
PORT=3000

# MongoDB URI (Atlas or Local)
MONGODB_URL=mongodb://localhost:27017/travel-planner

# JWT Secret config (for signatures)
JWT_SECRET=your_super_secret_jwt_string_needs_to_be_long
